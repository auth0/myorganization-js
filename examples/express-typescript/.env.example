# ====== Auth0 Configuration ======

# Your Auth0 tenant domain (e.g., tenant-name.us.auth0.com)
AUTH0_DOMAIN=your-tenant.auth0.com

# Client ID for your M2M application
AUTH0_CLIENT_ID=your-client-id

# Client Secret for your M2M application
# ⚠️  NEVER commit this to version control!
AUTH0_CLIENT_SECRET=your-client-secret

# Organization ID (e.g., org_123456789)
AUTH0_ORGANIZATION=org_123456789

# Optional: Custom audience (defaults to https://{domain}/api/org/)
# AUTH0_AUDIENCE=https://api.example.com

# Optional: Enable mTLS for enhanced security
# AUTH0_MTLS_ENABLED=false

# ====== Server Configuration ======
PORT=3000
NODE_ENV=development

# ====== Alternative: Private Key JWT (Enhanced Security) ======
# Uncomment to use Private Key JWT instead of client secret
# This provides enhanced security by using asymmetric cryptography

# AUTH0_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
# AUTH0_CLIENT_ASSERTION_SIGNING_ALG=RS256

# ====== Security Notes ======
# 1. Never expose client secrets or private keys in client-side code
# 2. Use environment variables or secure secret management (AWS Secrets Manager, Azure Key Vault, etc.)
# 3. Rotate credentials regularly (every 90 days recommended)
# 4. Use Private Key JWT in production for enhanced security
# 5. Enable mTLS for additional transport layer security
# 6. Monitor your Auth0 logs for suspicious activity
# 7. Grant minimal required scopes to your M2M application
