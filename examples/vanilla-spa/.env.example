# Auth0 Configuration
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_ORGANIZATION=org_123456789

# Custom audience (required to get a JWT access token instead of an opaque token)
VITE_AUTH0_AUDIENCE=https://your-tenant.auth0.com/my-org/

# Optional
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
VITE_AUTH0_LOGOUT_URI=http://localhost:5173

# ⚠️  SECURITY NOTE: Never include client secrets in SPA applications!
