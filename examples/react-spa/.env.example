# ====== Auth0 Configuration (Client-Side) ======

# Your Auth0 tenant domain
VITE_AUTH0_DOMAIN=your-tenant.auth0.com

# Your SPA application client ID
VITE_AUTH0_CLIENT_ID=your-spa-client-id

# Your organization ID
VITE_AUTH0_ORGANIZATION=org_123456789

# ⚠️  SECURITY NOTE ⚠️
# NEVER include client secrets in a SPA application!
# Client secrets should ONLY be used on the server-side.
# This example uses the token-based authentication pattern
# which is safe for browser/SPA applications.

# Optional: Custom audience
# VITE_AUTH0_AUDIENCE=https://api.example.com

# Optional: Redirect URIs
VITE_AUTH0_REDIRECT_URI=http://localhost:5173
VITE_AUTH0_LOGOUT_URI=http://localhost:5173
